backend/data/
**/data/

# ─── Logs ─────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── Editor / OS ──────────────────────────────────────────────────────────────
.DS_Store
.vscode/
.idea/
*.swp
*.swo

# ─── Tooling caches ───────────────────────────────────────────────────────────
.cache/
.parcel-cache/
.vite/
coverage/

# ─── Claude Code (local settings only — keep shared settings.json) ────────────
.claude/settings.local.json
