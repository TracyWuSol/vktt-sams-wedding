# ─── Dependencies ─────────────────────────────────────────────────────────────
node_modules/
.pnpm-store/

# ─── Build output ─────────────────────────────────────────────────────────────
dist/
build/
*.tsbuildinfo

# ─── Secrets (NEVER commit) ───────────────────────────────────────────────────
.env
wedding-photo-sharing/.env.example
!.env.example
!**/.env.example
!.env.template
!**/.env.template

# ─── Runtime data ─────────────────────────────────────────────────────────────
