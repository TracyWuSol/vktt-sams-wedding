# Production env template. Copy to backend/.env on the VM, chmod 600,
# and fill in real values. Both the backend AND the email-worker read
# from backend/.env (the worker resolves it relative to its own location).

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=4000
# Origin of the frontend. With the included Nginx config, the frontend is
# served from the same host as the API, so this is mainly used to set CORS
# allow-list for direct API calls in development.
FRONTEND_ORIGIN=http://localhost

# ─── AWS ──────────────────────────────────────────────────────────────────────
# Region of your S3 bucket and Rekognition collection.
AWS_REGION=ca-central-1

# Long-lived IAM user credentials. The IAM user should be service-only
# (no console login) and scoped via the policy in docs/aws-iam-policy.json.
# Leave BOTH blank to fall back to the default credential chain (e.g. an
# EC2/ECS instance role). The code switches modes automatically.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Only set these if you're using temporary STS/SSO credentials whose access
# key starts with ASIA. For long-lived AKIA keys leave them blank and set
# AWS_USE_SESSION_TOKEN=false.
AWS_SESSION_TOKEN=
AWS_USE_SESSION_TOKEN=false

AWS_S3_BUCKET=
AWS_REKOGNITION_COLLECTION=wedding-guests

# ─── Solace PubSub+ ───────────────────────────────────────────────────────────
# Cloud: tcps://mr-XXXXXXXX.messaging.solace.cloud:55443
# Self-hosted: tcp://your-broker-host:55555
SOLACE_HOST=
SOLACE_VPN_NAME=default
SOLACE_USERNAME=
SOLACE_PASSWORD=

# Queue the email-worker binds to. Must already exist on the broker with a
# topic subscription to: wedding/alerts/photos/email/>
EMAIL_SOLACE_QUEUE=wedding_alerts_email_queue

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
# For Gmail, use an App Password (NOT your account password).
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=

# ─── Twilio (optional — only needed if any guest uses SMS) ───────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_FROM=
