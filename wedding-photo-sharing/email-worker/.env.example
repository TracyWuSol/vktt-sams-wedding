# The email-worker reads its config from this file first and then falls back
# to ../backend/.env, so for local development you can keep all secrets in
# the backend's .env. In production each service should have its own .env.

# ─── Solace ──────────────────────────────────────────────────────────────────
SOLACE_HOST=tcp://localhost:55555
SOLACE_VPN_NAME=default
SOLACE_USERNAME=default
SOLACE_PASSWORD=

# Queue the worker binds to. It must be provisioned on the broker with a
# topic subscription to: wedding/alerts/photos/email/>
EMAIL_SOLACE_QUEUE=wedding_alerts_email_queue

# ─── Email (SMTP) ────────────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=your@gmail.com
