{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "S3PhotoBucketObjects",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject",
        "s3:DeleteObject"
      ],
      "Resource": "arn:aws:s3:::REPLACE_WITH_BUCKET_NAME/*"
    },
    {
      "Sid": "S3PhotoBucketListing",
      "Effect": "Allow",
      "Action": [
        "s3:ListBucket",
        "s3:GetBucketLocation"
      ],
      "Resource": "arn:aws:s3:::REPLACE_WITH_BUCKET_NAME"
    },
    {
      "Sid": "RekognitionCollectionScoped",
      "Effect": "Allow",
      "Action": [
        "rekognition:CreateCollection",
        "rekognition:DeleteCollection",
        "rekognition:DescribeCollection",
        "rekognition:IndexFaces",
        "rekognition:SearchFacesByImage",
        "rekognition:DeleteFaces",
        "rekognition:ListFaces"
      ],
      "Resource": "arn:aws:rekognition:REPLACE_WITH_REGION:REPLACE_WITH_ACCOUNT_ID:collection/REPLACE_WITH_COLLECTION_NAME"
    },
    {
      "Sid": "RekognitionDetectFaces",
      "Effect": "Allow",
      "Action": [
        "rekognition:DetectFaces"
      ],
      "Resource": "*"
    }
  ]
}
