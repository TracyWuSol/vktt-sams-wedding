# ─── Server ───────────────────────────────────────────────────────────────────
PORT=4000
FRONTEND_ORIGIN=http://localhost:5173

# ─── AWS ──────────────────────────────────────────────────────────────────────
# Leave blank to use IAM role / instance profile in production.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Required when using temporary STS/SSO credentials (key starts with ASIA).
AWS_SESSION_TOKEN=
# Set to "false" when using permanent AKIA credentials.
AWS_USE_SESSION_TOKEN=true

# S3 bucket for storing reference and event photos
AWS_S3_BUCKET=wedding-photos-demo

# Rekognition face collection (created automatically on first start)
AWS_REKOGNITION_COLLECTION=wedding-guests

# ─── Solace PubSub+ ───────────────────────────────────────────────────────────
# Solace Cloud: tcps://mr-XXXXXXXX.messaging.solace.cloud:55443
# Self-hosted:  tcp://your-host:55555
SOLACE_HOST=tcp://localhost:55555
SOLACE_VPN_NAME=default
SOLACE_USERNAME=default
SOLACE_PASSWORD=

# Queue consumed by the email-worker. Must be provisioned on the broker
# with a topic subscription to: wedding/alerts/photos/email/>
EMAIL_SOLACE_QUEUE=wedding_alerts_email_queue

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
# These are read by the email-worker. For Gmail, use an App Password.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=your@gmail.com

# ─── Twilio (SMS) ─────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=
TWILIO_SMS_FROM=+1XXXXXXXXXX
