# ─── Server ───────────────────────────────────────────────────────────────────
PORT=4000
FRONTEND_ORIGIN=http://localhost:5173

# ─── AWS ──────────────────────────────────────────────────────────────────────
# Leave blank to use IAM role / instance profile in production
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=      # required when using temporary STS/SSO credentials (key starts with ASIA)

# S3 bucket for storing reference and event photos
AWS_S3_BUCKET=wedding-photos-demo

# Rekognition face collection (created automatically on first start)
AWS_REKOGNITION_COLLECTION=wedding-guests

# ─── Solace PubSub+ ───────────────────────────────────────────────────────────
# Obtain from: Solace Cloud Console → Connect → SMF (Secured)
SOLACE_HOST=tcps://mr-XXXXXXXX.messaging.solace.cloud:55443
SOLACE_VPN_NAME=default
SOLACE_USERNAME=solace-cloud-client
SOLACE_PASSWORD=

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your@gmail.com
EMAIL_PASS=your-app-password        # use a Gmail App Password, not your main password
EMAIL_FROM=your@gmail.com

# ─── Twilio (SMS) ─────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=
TWILIO_SMS_FROM=+1XXXXXXXXXX
